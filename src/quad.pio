
; * =======================================================================================
; * quad
; * (c) Dr. Pedro E. Colla (LU7DZ) <pedro.colla@gmail.com>
; * 
; * Digital oscillator, produces a dual VFO signal in two consecutive pins
; * Sequence: 00 -> 00 -> 11 -> 11
; * =======================================================================================*/
.program quad
.wrap_target
    set pins, 0b00
    set pins, 0b00
    set pins, 0b11
    set pins, 0b11

.wrap
